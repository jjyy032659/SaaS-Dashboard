# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code local settings (may contain secrets in allowed commands)
.claude/settings.local.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# =============================================================================
# TERRAFORM
# =============================================================================
# These files contain sensitive information or are auto-generated.
# NEVER commit these to version control!

# Local .terraform directory (contains provider plugins)
**/.terraform/*

# Terraform state files (contain sensitive infrastructure details)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variables file with secrets (use terraform.tfvars.example as template)
*.tfvars
!*.tfvars.example

# Override files (local customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration file
.terraformrc
terraform.rc

# Lock file (optional - some teams commit this for consistency)
# Uncomment the next line if you want to ignore it
# .terraform.lock.hcl
